datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DONOR
  NGO
  DRIVER
  ADMIN
}

enum DriverStatus {
  PENDING_APPROVAL
  VERIFIED
  REJECTED
}

model User {
  id                String             @id @default(uuid())
  firebaseId        String             @unique
  email             String             @unique
  name              String
  roles             String             @default("DONOR") // Comma-separated roles: DONOR, NGO, DRIVER, ADMIN
  selfieUrl         String?            @db.Text
  alertRadiusKm     Int                @default(15) // Driver alert radius for nearby help notifications
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  driverDetails     DriverDetails?
  needsCreated      Need[]             @relation("NGONeeds")
  dispatches        DispatchTask[]     @relation("DriverDispatches")
  collectionCenters CollectionCenter[] @relation("UserCollectionCenters")
  donatedResources  Resource[]         @relation("DonorResources")
  teamId            String?
  team              Team?              @relation("TeamMembers", fields: [teamId], references: [id])
  createdTeams      Team[]             @relation("TeamCreator")
  shareLocationWithTeam Boolean          @default(false)
}

model DriverDetails {
  id             String       @id @default(uuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id])
  cedula         String       @unique
  vehicleDetails String
  licensePlate   String
  licenseDocUrl  String?
  status         DriverStatus @default(PENDING_APPROVAL)
  verifiedAt     DateTime?
}

enum ResourceCategory {
  MEDICINES
  FOOD
  BLOOD_DONORS
  HELPERS
  MACHINES
  RESCUE_TEAMS
}

model Resource {
  id                 String            @id @default(uuid())
  name               String
  category           ResourceCategory
  stockQuantity      Int               @default(0)
  expirationDate     DateTime? // Required if category is MEDICINES or FOOD
  donorId            String?
  donor              User?             @relation("DonorResources", fields: [donorId], references: [id])
  latitude           Float? // Origin location of this offer/stock
  longitude          Float?
  collectionCenterId String?
  collectionCenter   CollectionCenter? @relation("CenterResources", fields: [collectionCenterId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  stockTrans         StockTransaction[]
  needItems          NeedItem[]        @relation("RequestedResource")
  fulfilledItems     NeedItem[]        @relation("MatchedResource")
}

model StockTransaction {
  id          String   @id @default(uuid())
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id])
  quantity    Int // positive for additions, negative for deductions
  description String
  createdAt   DateTime @default(now())
}

enum NeedStatus {
  PENDING
  ALLOCATED
  FULFILLED
  CANCELLED
}

model Need {
  id                 String            @id @default(uuid())
  ngoId              String
  ngo                User              @relation("NGONeeds", fields: [ngoId], references: [id])
  description        String
  urgencyScore       Int // calculated priority: 1-100
  isImmediate        Boolean           @default(false) // urgencyScore >= 80 -> "ATENCIÓN INMEDIATA"
  state              String // Manual fallback for Estado
  sector             String // Manual fallback for Sector
  latitude           Float?
  longitude          Float?
  collectionCenterId String?
  collectionCenter   CollectionCenter? @relation("CenterNeeds", fields: [collectionCenterId], references: [id])
  originLatitude     Float? // Pickup/origin point — people waiting here
  originLongitude    Float?
  originLabel        String?
  status             NeedStatus        @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  items              NeedItem[]
  dispatchTasks      DispatchTask[]
}

model NeedItem {
  id                String    @id @default(uuid())
  needId            String
  need              Need      @relation(fields: [needId], references: [id])
  resourceId        String
  resource          Resource  @relation("RequestedResource", fields: [resourceId], references: [id])
  quantity          Int
  matchedResourceId String?
  matchedResource   Resource? @relation("MatchedResource", fields: [matchedResourceId], references: [id])
  pickupLatitude    Float?
  pickupLongitude   Float?
  pickupDistanceKm  Float?
  pickupLabel       String?
}

enum DispatchStatus {
  PROPOSED
  ACCEPTED
  EN_ROUTE
  ALERTA_CONEXION
  DELIVERED
  TIMED_OUT
  CANCELLED
}

model DispatchTask {
  id               String         @id @default(uuid())
  needId           String
  need             Need           @relation(fields: [needId], references: [id])
  driverId         String
  driver           User           @relation("DriverDispatches", fields: [driverId], references: [id])
  status           DispatchStatus @default(PROPOSED)
  proposedAt       DateTime       @default(now())
  acceptedAt       DateTime?
  timeoutAt        DateTime
  pickupLatitude   Float?
  pickupLongitude  Float?
  pickupLabel      String?
  signatureUrl     String?
  photoUrl         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model CollectionCenter {
  id          String     @id @default(uuid())
  name        String
  description String     @db.Text
  latitude    Float
  longitude   Float
  address     String?    @db.Text
  services    String // Comma-separated list of services, e.g. "Comida,Medicina,Refugio"
  createdById String?
  createdBy   User?      @relation("UserCollectionCenters", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resources   Resource[] @relation("CenterResources")
  needs       Need[]     @relation("CenterNeeds")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  creatorId   String
  creator     User     @relation("TeamCreator", fields: [creatorId], references: [id])
  members     User[]   @relation("TeamMembers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
