{
  "name": "aid-venezuela-app",
  "version": "1.0.0",
  "description": "Humanitarian aid coordination app for Venezuela",
  "main": "dist/main.js",
  "scripts": {
    "test": "jest",
    "build:backend": "prisma generate && nest build",
    "build:frontend": "next build src/client",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "prisma generate && nest start",
    "start:backend:dev": "prisma generate && nest start --watch",
    "start:frontend:dev": "next dev src/client",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "start:services:dev": "docker compose -f docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/platform-socket.io": "10.4.22",
    "@nestjs/websockets": "10.4.22",
    "@prisma/client": "5.22.0",
    "bullmq": "5.79.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "firebase": "12.15.0",
    "firebase-admin": "14.1.0",
    "ioredis": "5.11.1",
    "leaflet": "1.9.4",
    "mysql2": "3.22.5",
    "next": "14.2.35",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.22",
    "@types/express": "4.17.25",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.43",
    "@types/passport-jwt": "4.0.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
