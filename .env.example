# =========================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - aid-venezuela-app
# =========================================================================

# -------------------------------------------------------------------------
# Dominio y Certificados SSL (Traefik)
# -------------------------------------------------------------------------
UI_DOMAIN=aidvenezuela.org
API_DOMAIN=api.aidvenezuela.org
LETSENCRYPT_EMAIL=admin@aidvenezuela.org

# -------------------------------------------------------------------------
# Conexiones de Base de Datos y Caché
# -------------------------------------------------------------------------
# NOTA: En docker-compose.prod.yml, el host de la DB es "mysql-aid-production"
# y el host de Redis es "redis-aid-production".
MYSQL_ROOT_PASSWORD=aidpassword
DATABASE_URL=mysql://root:aidpassword@mysql-aid-production:3306/aid_venezuela
REDIS_URL=redis://redis-aid-production:6379

# Puerto local del servidor (NestJS)
PORT=5001
NODE_ENV=production

# -------------------------------------------------------------------------
# Firebase Admin SDK (Requerido por el Backend de NestJS)
# -------------------------------------------------------------------------
# Las credenciales de la cuenta de servicio de Firebase se pueden cargar 
# mediante un archivo JSON o inyectando las claves directamente:
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json

# Alternativa (si no usas el archivo JSON anterior, llena estas variables):
FIREBASE_PROJECT_ID=su-id-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@su-proyecto.iam.gserviceaccount.com
# Reemplaza los saltos de línea con \n en la private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# Notificaciones Web Push (VAPID)
# -------------------------------------------------------------------------
# Puedes generar este par de claves en consola corriendo: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=su-vapid-public-key
VAPID_PRIVATE_KEY=su-vapid-private-key
VAPID_SUBJECT=mailto:admin@aidvenezuela.org

# -------------------------------------------------------------------------
# Integraciones de Alertas y Mensajería (Opcionales)
# -------------------------------------------------------------------------
MAILGUN_API_KEY=su-mailgun-api-key
MAILGUN_API_URL=https://api.mailgun.net
SECURITY_ALERT_EMAIL_TO=alertas-admin@aidvenezuela.org
SECURITY_ALERT_EMAIL_FROM=alertas-sistema@aidvenezuela.org

# -------------------------------------------------------------------------
# Motores de Inteligencia Artificial (Opcionales para priorización inteligente)
# -------------------------------------------------------------------------
GOOGLE_AI_API_KEY=su-google-gemini-api-key
OPENAI_API_KEY=su-openai-api-key

# =========================================================================
# CONFIGURACIÓN DE COMPILACIÓN FRONTEND (Para GitHub Secrets / Actions)
# =========================================================================
# Estas variables deben registrarse en GitHub Secrets para compilar Next.js:
# NEXT_PUBLIC_API_URL=https://api.aidvenezuela.org
# NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
